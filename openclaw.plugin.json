{
  "id": "mautic-control",
  "name": "Mautic Control",
  "description": "Typed tools for controlling the local Mautic stack through its REST APIs and safe maintenance bridge.",
  "version": "0.1.0",
  "contracts": {
    "tools": [
      "mautic_status",
      "mautic_request",
      "mautic_entity",
      "mautic_webhook_triggers",
      "mautic_console",
      "mautic_workspace_file"
    ]
  },
  "toolMetadata": {
    "mautic_status": { "optional": true },
    "mautic_request": { "optional": true },
    "mautic_entity": { "optional": true },
    "mautic_webhook_triggers": { "optional": true },
    "mautic_console": { "optional": true },
    "mautic_workspace_file": { "optional": true }
  },
  "activation": {
    "onStartup": true
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "baseUrl": {
        "type": "string",
        "default": "http://mautic_web",
        "description": "Base URL OpenClaw uses to reach the Mautic web container."
      },
      "consoleUrl": {
        "type": "string",
        "default": "http://mautic_console:8099/console",
        "description": "Internal console bridge URL for safe maintenance commands."
      },
      "workspaceRoot": {
        "type": "string",
        "default": "/workspace/mautic",
        "description": "Workspace directory exposed to mautic_workspace_file."
      },
      "allowedWorkspaceRoot": {
        "type": "string",
        "default": "/workspace/mautic",
        "description": "Hard path guard. workspaceRoot and all file operations must stay under this directory."
      },
      "defaultApiVersion": {
        "type": "string",
        "enum": ["legacy", "v2"],
        "default": "legacy",
        "description": "Default API mapping used by mautic_entity when apiVersion is omitted."
      },
      "requestTimeoutSeconds": {
        "type": "number",
        "minimum": 5,
        "maximum": 600,
        "default": 60,
        "description": "Timeout for Mautic HTTP API and dashboard probes."
      },
      "allowedConsoleCommands": {
        "type": "array",
        "uniqueItems": true,
        "default": [
          "cache:clear",
          "mautic:cache:clear",
          "migrations:status",
          "webhooks:process",
          "campaigns:rebuild",
          "campaigns:trigger",
          "segments:update",
          "plugins:reload"
        ],
        "items": {
          "type": "string",
          "enum": [
            "cache:clear",
            "mautic:cache:clear",
            "migrations:status",
            "webhooks:process",
            "campaigns:rebuild",
            "campaigns:trigger",
            "segments:update",
            "plugins:reload"
          ]
        },
        "description": "Optional narrower command policy. Commands must also be in the plugin's hardcoded safe allowlist."
      }
    }
  }
}
